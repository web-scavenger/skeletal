{
  "name": "skeletal-ui",
  "version": "0.4.0",
  "type": "module",
  "description": "Automate skeleton loading screens for React/Next.js TypeScript projects",
  "license": "MIT",
  "bin": {
    "skeletal-ui": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next/index.js",
      "types": "./dist/next/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite/index.js",
      "types": "./dist/vite/index.d.ts"
    },
    "./next-transform": {
      "import": "./dist/next-transform/index.js",
      "types": "./dist/next-transform/index.d.ts"
    },
    "./styles.css": "./dist/primitives/styles.css"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && copyfiles -u 1 src/primitives/styles.css dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.44",
    "react": ">=18",
    "react-dom": ">=18",
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "jiti": "^2.0.0",
    "neverthrow": "^8.0.0",
    "ts-morph": "^23.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "copyfiles": "^2.4.1",
    "jsdom": "^29.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
